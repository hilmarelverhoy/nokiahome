@model List<NokiaHome.Models.Linear.LinearProject>
@{
    ViewData["Title"] = "Projects";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Projects</h2>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr; Back to issues</a>
</div>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

@if (!Model.Any())
{
    <p class="text-muted">No projects found.</p>
}
else
{
    <div class="d-flex flex-column gap-2">
        @foreach (var project in Model)
        {
            var dotColor = string.IsNullOrEmpty(project.Color) ? "#6c757d" : project.Color;
            <a asp-action="ProjectDetail" asp-route-id="@project.Id"
               class="d-block text-decoration-none p-3 rounded border bg-white text-dark">
                <div class="d-flex align-items-start justify-content-between">
                    <div class="d-flex align-items-center gap-2">
                        <span style="display:inline-block;width:12px;height:12px;border-radius:50%;background:@dotColor;flex-shrink:0;margin-top:3px"></span>
                        <div>
                            <div class="fw-semibold">
                                @if (!string.IsNullOrEmpty(project.Icon))
                                {
                                    <span class="me-1">@project.Icon</span>
                                }
                                @project.Name
                            </div>
                            @if (!string.IsNullOrEmpty(project.Description))
                            {
                                <div class="text-muted small mt-1">@project.Description</div>
                            }
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2 ms-3 flex-shrink-0">
                        @if (project.State != null)
                        {
                            <span class="badge bg-@project.StateBadgeClass">@project.StateLabel</span>
                        }
                        @if (project.Progress.HasValue)
                        {
                            <span class="text-muted small">@((int)(project.Progress.Value * 100))%</span>
                        }
                    </div>
                </div>
                @if (project.Progress.HasValue && project.Progress.Value > 0)
                {
                    <div class="progress mt-2" style="height:4px">
                        <div class="progress-bar bg-dark" role="progressbar"
                             style="width:@((int)(project.Progress.Value * 100))%"
                             aria-valuenow="@((int)(project.Progress.Value * 100))"
                             aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                }
            </a>
        }
    </div>
}
