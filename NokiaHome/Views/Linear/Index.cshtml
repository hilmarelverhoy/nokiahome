@model NokiaHome.Models.Linear.LinearIssueListResult
@{
    ViewData["Title"] = "Issues";
    var states = ViewBag.States as List<NokiaHome.Models.Linear.LinearWorkflowState> ?? new();
    var customViews = ViewBag.CustomViews as List<NokiaHome.Models.Linear.LinearCustomView> ?? new();
    var issueViews = customViews.Where(v => v.ModelName == "Issue").ToList();
    var inView = !string.IsNullOrEmpty(Model.ActiveViewId);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">
        @if (inView)
        {
            <span class="text-muted fw-normal fs-5 me-2">View:</span>@Model.ActiveViewName
        }
        else
        {
            <span>Issues</span>
        }
    </h2>
    <div class="d-flex gap-2">
        <a asp-action="KjopCreate" class="btn btn-sm btn-outline-secondary">+ Kjøp</a>
        <a asp-action="QuickCreate" class="btn btn-sm btn-dark">+ New issue</a>
    </div>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}
@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

@* Custom views — stacked vertically *@
@if (issueViews.Any())
{
    <div class="mb-4">
        <div class="text-muted small fw-medium mb-2" style="letter-spacing:.04em">VIEWS</div>
        <div class="d-flex flex-column gap-1">
            @* "All issues" to reset back to default list *@
            <a asp-action="Index"
               class="d-flex align-items-center gap-2 text-decoration-none px-3 py-2 rounded border @(!inView ? "bg-dark text-white border-dark" : "bg-white text-dark")"
               style="font-size:.9rem">
                All issues
            </a>
            @foreach (var view in issueViews)
            {
                var isActive = Model.ActiveViewId == view.Id;
                var dotColor = string.IsNullOrEmpty(view.Color) ? "#6c757d" : view.Color;
                <a asp-action="Index" asp-route-viewId="@view.Id"
                   class="d-flex align-items-center gap-2 text-decoration-none px-3 py-2 rounded border @(isActive ? "bg-dark text-white border-dark" : "bg-white text-dark")"
                   style="font-size:.9rem"
                   title="@view.Description">
                    <span style="width:8px;height:8px;border-radius:50%;background:@dotColor;flex-shrink:0"></span>
                    @if (!string.IsNullOrEmpty(view.Icon))
                    {
                        <span>@view.Icon</span>
                    }
                    @view.Name
                </a>
            }
        </div>
    </div>
}

@if (!Model.Issues.Any())
{
    <p class="text-muted">No issues found.</p>
}
else
{
    @foreach (var issue in Model.Issues)
    {
        var priorityIcon = issue.Priority switch
        {
            1 => "U",
            2 => "H",
            3 => "M",
            4 => "L",
            _ => "—"
        };
        <div class="d-flex align-items-stretch border-bottom py-2">
            <div class="flex-grow-1 pe-2 min-w-0">
                <div class="text-truncate">
                    <a asp-action="Detail" asp-route-id="@issue.Id"
                       class="text-decoration-none text-dark fw-medium" style="font-size:.85rem">@issue.Title</a>
                </div>
                <div class="d-flex flex-wrap gap-2 mt-1 align-items-center">
                    <span class="text-muted font-monospace" style="font-size:.7rem">@issue.Identifier</span>
                    @if (issue.State != null)
                    {
                        <span class="badge" style="font-size:.65rem;background-color:@issue.State.Color !important">@issue.State.Name</span>
                    }
                    <span class="badge bg-@issue.PriorityBadgeClass text-dark" style="font-size:.65rem" title="@issue.PriorityLabel">@priorityIcon</span>
                </div>
            </div>
            <div class="d-flex align-items-stretch flex-shrink-0">
                <a asp-action="Detail" asp-route-id="@issue.Id"
                   class="btn btn-sm btn-outline-secondary d-flex align-items-center px-2" style="font-size:.75rem">View</a>
            </div>
        </div>
    }

    @* Pagination — threads viewId through so it stays active across pages *@
    @if (Model.PageInfo?.HasNextPage == true || Model.AfterCursor != null)
    {
        <div class="d-flex gap-2 mt-2">
            @if (Model.AfterCursor != null)
            {
                <a asp-action="Index"
                   asp-route-viewId="@Model.ActiveViewId"
                   asp-route-stateFilter="@Model.StateFilter"
                   class="btn btn-outline-secondary btn-sm">&larr; Back</a>
            }
            @if (Model.PageInfo?.HasNextPage == true)
            {
                <a asp-action="Index"
                   asp-route-viewId="@Model.ActiveViewId"
                   asp-route-stateFilter="@Model.StateFilter"
                   asp-route-after="@Model.PageInfo.EndCursor"
                   class="btn btn-outline-secondary btn-sm">Next &rarr;</a>
            }
        </div>
    }
}

@* State filter — vertical, below the list, only shown when not inside a view *@
@if (!inView)
{
    <div class="mt-4">
        <div class="text-muted small fw-medium mb-2" style="letter-spacing:.04em">FILTER BY STATE</div>
        <div class="d-flex flex-column gap-1">
            <a class="text-decoration-none px-3 py-2 rounded border @(Model.StateFilter == null ? "bg-dark text-white border-dark" : "bg-white text-dark")"
               asp-action="Index"
               style="font-size:.85rem">All</a>
            @foreach (var state in states)
            {
                <a class="text-decoration-none px-3 py-2 rounded border @(Model.StateFilter == state.Id ? "bg-dark text-white border-dark" : "bg-white text-dark")"
                   asp-action="Index"
                   asp-route-stateFilter="@state.Id"
                   style="font-size:.85rem">@state.Name</a>
            }
        </div>
    </div>
}
