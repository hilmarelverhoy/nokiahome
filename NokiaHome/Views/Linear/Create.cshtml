@model NokiaHome.Models.Linear.CreateIssueViewModel
@{
    ViewData["Title"] = "New issue";
}

<div class="mb-3">
    <a asp-action="Index" class="text-decoration-none text-muted small">&larr; Back to issues</a>
</div>

<h2 class="mb-4">New issue</h2>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

<div class="row">
    <div class="col-lg-7">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="StateId" type="hidden" />

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-medium">Title <span class="text-danger">*</span></label>
                <input asp-for="Title" class="form-control" placeholder="Short, descriptive title"
                       required autofocus />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-medium">Description</label>
                <textarea asp-for="Description" class="form-control" rows="6"
                          placeholder="Describe the issue in markdown..."></textarea>
            </div>

            @if (Model.AvailableLabels.Any())
            {
                <div class="mb-3">
                    <label class="form-label fw-medium">Labels</label>
                    <div class="d-flex flex-wrap gap-2">
                        <partial name="_LabelPicker" model="@((Model.AvailableLabels, Model.LabelIds))" />
                    </div>
                </div>
            }

            <div class="d-flex gap-2 flex-wrap">
                <button type="submit" name="Priority" value="1" class="btn btn-danger">Urgent</button>
                <button type="submit" name="Priority" value="2" class="btn btn-warning">High</button>
                <button type="submit" name="Priority" value="3" class="btn btn-primary">Medium</button>
                <button type="submit" name="Priority" value="4" class="btn btn-secondary">Low</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
