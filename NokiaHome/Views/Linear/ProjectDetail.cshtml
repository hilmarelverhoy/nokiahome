@model NokiaHome.Models.Linear.LinearProjectDetailViewModel
@{
    ViewData["Title"] = Model.Project.Name.Length > 0 ? Model.Project.Name : "Project";
    var project = Model.Project;
    var dotColor = string.IsNullOrEmpty(project.Color) ? "#6c757d" : project.Color;
    var allStates = new[] { "planned", "inProgress", "paused", "completed", "cancelled" };
}

<div class="mb-3">
    <a asp-action="Projects" class="text-decoration-none text-muted small">&larr; Back to projects</a>
</div>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

@* Project header *@
<div class="mb-3">
    <div class="mb-1">
        <span style="display:inline-block;width:12px;height:12px;border-radius:50%;background:@dotColor;vertical-align:middle;margin-right:6px"></span>
        <span class="fw-semibold" style="font-size:1.4rem;vertical-align:middle">
            @if (!string.IsNullOrEmpty(project.Icon))
            {
                <span>@project.Icon </span>
            }@project.Name
        </span>
        @if (project.State != null)
        {
            <span class="badge bg-@project.StateBadgeClass" style="margin-left:6px;vertical-align:middle">@project.StateLabel</span>
        }
    </div>
    @if (!string.IsNullOrEmpty(project.Description))
    {
        <p class="text-muted mb-2">@project.Description</p>
    }
    @if (project.Progress.HasValue)
    {
        <div class="progress mb-1" style="height:6px">
            <div class="progress-bar bg-dark" role="progressbar"
                 style="width:@((int)(project.Progress.Value * 100))%"
                 aria-valuenow="@((int)(project.Progress.Value * 100))"
                 aria-valuemin="0" aria-valuemax="100"></div>
        </div>
        <span class="text-muted small">@((int)(project.Progress.Value * 100))% complete</span>
    }
</div>

@* Change project state *@
<div class="card mb-3">
    <div class="card-body p-2">
        <div class="text-muted mb-1" style="font-size:.7rem">Project state</div>
        <div style="display:flex;gap:.3rem;flex-wrap:wrap">
            @foreach (var s in allStates)
            {
                var label = s switch {
                    "inProgress" => "In Progress",
                    "completed"  => "Completed",
                    "cancelled"  => "Cancelled",
                    "paused"     => "Paused",
                    "planned"    => "Planned",
                    _ => s
                };
                var isActive = project.State == s;
                <form asp-action="UpdateProjectState" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="projectId" value="@project.Id" />
                    <input type="hidden" name="state" value="@s" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                    <button type="submit"
                            class="btn btn-sm @(isActive ? "btn-dark" : "btn-outline-secondary")"
                            style="font-size:.72rem">@label</button>
                </form>
            }
        </div>
    </div>
</div>

@* Issues list *@
<h5 class="mb-2">Issues</h5>

@if (!Model.Issues.Any())
{
    <p class="text-muted">No issues in this project.</p>
}
else
{
    @foreach (var issue in Model.Issues)
    {
        <partial name="_IssueRow" model="issue" />
    }

    @* Pagination *@
    @if (Model.PageInfo?.HasNextPage == true || Model.AfterCursor != null)
    {
        <div class="mt-2">
            @if (Model.AfterCursor != null)
            {
                <a asp-action="ProjectDetail"
                   asp-route-id="@project.Id"
                   class="btn btn-outline-secondary btn-sm">&larr; Back</a>
            }
            @if (Model.PageInfo?.HasNextPage == true)
            {
                <a asp-action="ProjectDetail"
                   asp-route-id="@project.Id"
                   asp-route-after="@Model.PageInfo.EndCursor"
                   class="btn btn-outline-secondary btn-sm">Next &rarr;</a>
            }
        </div>
    }
}
