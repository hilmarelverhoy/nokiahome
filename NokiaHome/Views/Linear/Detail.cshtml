@model NokiaHome.Models.Linear.LinearIssue
@{
    ViewData["Title"] = Model != null ? $"{Model.Identifier} — {Model.Title}" : "Issue";
    var projects = ViewBag.Projects as List<NokiaHome.Models.Linear.LinearProject> ?? new();
}

<div class="mb-3">
    <a asp-action="Index" class="text-decoration-none text-muted small">&larr; Back to issues</a>
</div>

@if (ViewBag.ErrorMessage != null)
{
    <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
}

@if (Model == null)
{
    <p class="text-muted">Issue not found.</p>
}
else
{
@* Header *@
<div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.25rem">
    <span class="text-muted font-monospace" style="font-size:.7rem">@Model.Identifier</span>
    <a href="@Model.Url" target="_blank" rel="noopener"
       class="text-muted" style="font-size:.7rem" title="Open in Linear">↗</a>
    <a asp-action="EditIssue" asp-route-id="@Model.Id"
       class="text-muted" style="font-size:.7rem;margin-left:auto" title="Edit issue">Edit</a>
</div>
<p class="fw-medium mb-2" style="font-size:.9rem">@Model.Title</p>

@* Metadata *@
<dl class="mb-2" style="display:grid;grid-template-columns:auto 1fr;gap:.25rem .75rem">
    <dt class="text-muted" style="font-size:.7rem">State</dt>
    <dd class="mb-0">
        <partial name="_StateBadge" model="Model.State" />
    </dd>
    <dt class="text-muted" style="font-size:.7rem">Priority</dt>
    <dd class="mb-0">
        <span class="badge bg-@Model.PriorityBadgeClass text-dark" style="font-size:.65rem">@Model.PriorityLabel</span>
    </dd>
    <dt class="text-muted" style="font-size:.7rem">Assignee</dt>
    <dd class="mb-0" style="font-size:.7rem">@(Model.Assignee?.Name ?? "—")</dd>
    <dt class="text-muted" style="font-size:.7rem">Team</dt>
    <dd class="mb-0" style="font-size:.7rem">@(Model.Team?.Name ?? "—")</dd>
    @if (Model.Project != null)
    {
        <dt class="text-muted" style="font-size:.7rem">Project</dt>
        <dd class="mb-0" style="font-size:.7rem">
            <a asp-action="ProjectDetail" asp-route-id="@Model.Project.Id"
               class="text-decoration-none">@Model.Project.Name</a>
        </dd>
    }
    @if (Model.Labels?.Nodes?.Any() == true)
    {
        <dt class="text-muted" style="font-size:.7rem">Labels</dt>
        <dd class="mb-0">
            @foreach (var lbl in Model.Labels.Nodes)
            {
                <span class="badge me-1" style="background:@lbl.Color;font-size:.62rem">@lbl.Name</span>
            }
        </dd>
    }
    <dt class="text-muted" style="font-size:.7rem">Created</dt>
    <dd class="mb-0" style="font-size:.7rem">@Model.CreatedAt.ToString("dd MMM yyyy")</dd>
    <dt class="text-muted" style="font-size:.7rem">Updated</dt>
    <dd class="mb-0" style="font-size:.7rem">@Model.UpdatedAt.ToString("dd MMM yyyy")</dd>
</dl>

@* Change priority *@
<partial name="_PriorityEditor" model="Model" />

@* Change state *@
<partial name="_StateEditor" model="Model" />

@* Move to project *@
@if (projects.Any())
{
    <div class="card mb-2">
        <div class="card-body p-2">
            <div class="text-muted mb-1" style="font-size:.7rem">Move to project</div>
            <form asp-action="MoveToProject" method="post" style="display:flex;gap:.4rem;align-items:center">
                @Html.AntiForgeryToken()
                <input type="hidden" name="issueId" value="@Model.Id" />
                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                <select name="projectId" class="form-select form-select-sm" style="font-size:.75rem">
                    <option value="">— No project —</option>
                    @foreach (var proj in projects)
                    {
                        <option value="@proj.Id">
                            @(!string.IsNullOrEmpty(proj.Icon) ? proj.Icon + " " : "")@proj.Name
                        </option>
                    }
                </select>
                <button type="submit" class="btn btn-sm btn-outline-secondary" style="font-size:.75rem;white-space:nowrap">Move</button>
            </form>
        </div>
    </div>
}

@* Description *@
@if (!string.IsNullOrWhiteSpace(Model.Description))
{
    <div class="card mb-2">
        <div class="card-body p-2">
            <div class="text-muted mb-1" style="font-size:.7rem">Description</div>
            <div style="white-space:pre-wrap;font-size:.8rem">@Model.Description</div>
        </div>
    </div>
}

@* Comments *@
var comments = Model.Comments?.Nodes ?? new List<NokiaHome.Models.Linear.LinearComment>();
<div class="text-muted mb-1" style="font-size:.7rem">Comments (@comments.Count)</div>
@if (!comments.Any())
{
    <p class="text-muted" style="font-size:.75rem">No comments yet.</p>
}
else
{
    @foreach (var comment in comments)
    {
        <div class="card mb-1">
            <div class="card-body p-2">
                <div class="fw-medium" style="font-size:.75rem">@(comment.User?.Name ?? "Unknown")</div>
                <div class="text-muted" style="font-size:.65rem">@comment.CreatedAt.ToString("dd MMM yyyy HH:mm")</div>
                <div class="mt-1" style="white-space:pre-wrap;font-size:.8rem">@comment.Body</div>
            </div>
        </div>
    }
}

@* Add comment *@
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger py-1 px-2 mt-2" style="font-size:.75rem">@TempData["ErrorMessage"]</div>
}
<form asp-action="AddComment" method="post" class="mt-2">
    @Html.AntiForgeryToken()
    <input type="hidden" name="issueId" value="@Model.Id" />
    <div class="mb-1">
        <textarea name="body" rows="3" class="form-control form-control-sm"
                  placeholder="Add a comment…" style="font-size:.8rem;resize:vertical"></textarea>
    </div>
    <div style="display:flex;gap:.5rem;align-items:center">
        <button type="submit" class="btn btn-sm btn-primary" style="font-size:.75rem">Add comment</button>
    </div>
</form>

@* Archive *@
<div class="mt-4 pt-3" style="border-top:1px solid #dee2e6">
    <form asp-action="ArchiveIssue" method="post"
          onsubmit="return confirm('Archive this issue? It will be hidden from the default issue list.')">
        @Html.AntiForgeryToken()
        <input type="hidden" name="issueId" value="@Model.Id" />
        <input type="hidden" name="returnUrl" value="@Url.Action("Index")" />
        <button type="submit" class="btn btn-sm btn-outline-danger" style="font-size:.75rem">Archive issue</button>
    </form>
</div>
}

