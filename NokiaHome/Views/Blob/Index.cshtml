@using Azure.Storage.Blobs.Models
@model IReadOnlyList<BlobItem>
@{
    ViewData["Title"] = "Blob Storage";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Blob Storage</h1>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header">Upload file</div>
    <div class="card-body">
        <form asp-action="Upload" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="input-group">
                <input type="file" name="file" class="form-control" required />
                <button class="btn btn-primary" type="submit">Upload</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">Files (@Model.Count)</div>
    @if (Model.Count == 0)
    {
        <div class="card-body text-muted">No files uploaded yet.</div>
    }
    else
    {
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Size</th>
                    <th>Last modified</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var blob in Model)
                {
                    <tr>
                        <td class="align-middle">@blob.Name</td>
                        <td class="align-middle text-end text-nowrap">
                            <a asp-action="Download" asp-route-name="@blob.Name"
                               class="btn btn-sm btn-outline-secondary me-1">Download</a>
                            @if (blob.Name.EndsWith(".zip", StringComparison.OrdinalIgnoreCase))
                            {
                                <form asp-action="Unzip" method="post" class="d-inline me-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="name" value="@blob.Name" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Unzip</button>
                                </form>
                            }
                        </td>
                    </tr>
                    <tr>
                        <td class="align-middle text-nowrap">@blob.Properties.LastModified?.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <form asp-action="Delete" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete @blob.Name?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="name" value="@blob.Name" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                        <td>
                            @if (blob.Name.EndsWith(".zip", StringComparison.OrdinalIgnoreCase))
                            {
                                <form asp-action="Unzip" method="post" class="d-inline me-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="name" value="@blob.Name" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Unzip</button>
                                </form>
                            }
                    </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@functions {
    static string FormatSize(long? bytes)
    {
        if (bytes is null) return "-";
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }
}
