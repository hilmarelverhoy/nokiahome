@model NokiaHome.Models.JournalEntry
@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-4">
    <a asp-action="Index" class="text-decoration-none text-muted small">&larr; All entries</a>
</div>

<div class="d-flex justify-content-between align-items-start mb-3">
    <h1 class="h3 mb-0">@Model.Title</h1>
    <form asp-action="Delete" method="post" class="ms-3 flex-shrink-0"
          onsubmit="return confirm('Delete this entry?')">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
    </form>
</div>

<p class="text-muted small mb-4">
    @Model.CreatedAt.ToLocalTime().ToString("dddd, MMMM d, yyyy 'at' HH:mm")
</p>

<div class="card">
    <div class="card-body">
        <pre class="mb-0" style="white-space: pre-wrap; word-break: break-word; font-family: inherit; font-size: 1rem; line-height: 1.7;">@Model.Body</pre>
    </div>
</div>
