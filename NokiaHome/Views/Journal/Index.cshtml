@model NokiaHome.Models.JournalIndexViewModel
@{
    ViewData["Title"] = "Journal";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Journal</h1>
    <span class="text-muted small">@Model.Entries.Count @(Model.Entries.Count == 1 ? "entry" : "entries")</span>
</div>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible" role="alert">
        @success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible" role="alert">
        @error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-4">
    <div class="card-header">New entry</div>
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Form.Title" class="form-label">Title <span class="text-danger">*</span></label>
                    <input asp-for="Form.Title" class="form-control" placeholder="Entry title" />
                    <span asp-validation-for="Form.Title" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Form.Body" class="form-label">Text</label>
                    <textarea asp-for="Form.Body" class="form-control font-monospace" rows="8"
                              placeholder="Paste or write your text here…"></textarea>
                    <span asp-validation-for="Form.Body" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label class="form-label text-muted">Or upload a .txt file</label>
                    <input type="file" name="file" accept=".txt,text/plain" class="form-control" />
                    <div class="form-text">If a file is uploaded its content replaces any text written above.</div>
                </div>

                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Save entry</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.Entries.Count == 0)
{
    <p class="text-muted">No entries yet.</p>
}
else
{
    <div class="list-group">
        @foreach (var entry in Model.Entries)
        {
            <a asp-action="Detail" asp-route-id="@entry.Id"
               class="list-group-item list-group-item-action d-flex justify-content-between align-items-start py-3">
                <div class="me-3 overflow-hidden">
                    <div class="fw-semibold text-truncate">@entry.Title</div>
                    <div class="text-muted small text-truncate">@entry.Body.Replace('\n', ' ')</div>
                </div>
                <small class="text-muted text-nowrap">@entry.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</small>
            </a>
        }
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
