@model NokiaHome.Models.VoiceConfirmViewModel
@{
    ViewData["Title"] = "Confirm event";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Confirm event</h1>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Cancel</a>
</div>

<div class="card mb-4">
    <div class="card-header text-muted" style="font-size:.85rem">Transcription</div>
    <div class="card-body">
        <p class="mb-0" style="white-space:pre-wrap">@Model.Transcription</p>
    </div>
</div>

<div class="card">
    <div class="card-header">Review and save</div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Form.Title" class="form-label">Title <span class="text-danger">*</span></label>
                    <input asp-for="Form.Title" class="form-control" />
                    <span asp-validation-for="Form.Title" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Form.Start" class="form-label">Start <span class="text-danger">*</span></label>
                    <input asp-for="Form.Start" type="datetime-local" class="form-control" />
                    <span asp-validation-for="Form.Start" class="text-danger small"></span>
                </div>

                <div class="col-md-6" id="end-field">
                    <label asp-for="Form.End" class="form-label">End <span class="text-danger">*</span></label>
                    <input asp-for="Form.End" type="datetime-local" class="form-control" />
                    <span asp-validation-for="Form.End" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="Form.AllDay" class="form-check-input" id="allDayCheck" />
                        <label class="form-check-label" for="allDayCheck">All-day event</label>
                    </div>
                </div>

                <div class="col-md-6">
                    <label asp-for="Form.Location" class="form-label">Location</label>
                    <input asp-for="Form.Location" class="form-control" />
                </div>

                <div class="col-12">
                    <label asp-for="Form.Description" class="form-label">Description</label>
                    <textarea asp-for="Form.Description" class="form-control" rows="2"></textarea>
                </div>

                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Save event</button>
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">Discard</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const allDay = document.getElementById('allDayCheck');
        const endField = document.getElementById('end-field');
        function syncEndField() { endField.style.display = allDay.checked ? 'none' : ''; }
        allDay.addEventListener('change', syncEndField);
        syncEndField();
    </script>
}
