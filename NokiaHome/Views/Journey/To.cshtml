@{
    ViewData["Title"] = "Select Destination";
    var fromCode        = ViewBag.FromCode as string;
    var fromName        = ViewBag.FromName as string;
    var fromCoordinates = ViewBag.FromCoordinates as string;
    var originHasStopId = !string.IsNullOrEmpty(fromCode) && fromCode.Contains(":");
}

@* Helper: route to GetTrip when both have stop codes, otherwise GetTripWithCoordinates *@
@{
    string DestinationUrl(string? toCode, string? toName, string? toCoords)
    {
        if (originHasStopId && !string.IsNullOrEmpty(toCode) && toCode.Contains(":"))
        {
            return Url.Action("GetTrip", new { fromCode = fromCode, toCode })!;
        }
        return Url.Action("GetTripWithCoordinates", new {
            fromCode = originHasStopId ? fromCode : null,
            fromName = originHasStopId ? null : fromName,
            fromCoordinates = originHasStopId ? null : fromCoordinates,
            toCode,
            toName,
            toCoordinates = toCoords
        })!;
    }
}

<div class="container mt-4">
    <div class="alert alert-info">
        <strong>From:</strong> @fromName
    </div>
    
    <h2>Where are you traveling to?</h2>
    
    <div class="row mt-4">
        <div class="col-12">
            <h4>Quick Select</h4>
            <div class="d-grid gap-2 d-md-block">
                <a href="@DestinationUrl(null, "Jobben", "10.711562,59.930349")" class="btn btn-success btn-lg me-2 mb-2">Jobben</a>
                <a href="@DestinationUrl(null, "Hjem", "10.746254,59.917774")" class="btn btn-success btn-lg me-2 mb-2">Hjem</a>
                <a href="@DestinationUrl("NSR:StopPlace:59872", "Oslo S", null)" class="btn btn-success btn-lg me-2 mb-2">Oslo S</a>
                <a href="@DestinationUrl("NSR:StopPlace:59977", "Trondheim S", null)" class="btn btn-success btn-lg me-2 mb-2">Trondheim S</a>
                <a href="@DestinationUrl("NSR:StopPlace:4411", "Hovedøya", null)" class="btn btn-success btn-lg me-2 mb-2">Hovedøya</a>
                <a href="@DestinationUrl("NSR:StopPlace:58382", "Aker Brygge", null)" class="btn btn-success btn-lg me-2 mb-2">Aker Brygge</a>
            </div>
        </div>
    </div>
    
    <div class="row mt-5">
        <div class="col-12">
            <h4>Or search for a location</h4>
            <form asp-action="SearchTo" method="post" class="d-flex">
                <input type="hidden" name="fromCode" value="@fromCode">
                <input type="hidden" name="fromName" value="@fromName">
                <input type="hidden" name="fromCoordinates" value="@fromCoordinates">
                <input type="text" name="searchText" class="form-control me-2" placeholder="Enter destination name..." required>
                <button type="submit" class="btn btn-outline-success">Search</button>
            </form>
        </div>
    </div>
    
    <div class="row mt-3">
        <div class="col-12">
            <a href="@Url.Action("From")" class="btn btn-secondary">← Back to From</a>
        </div>
    </div>
</div>
