@model NokiaHome.Models.Geocoding.GeocodingResponse
@{
    ViewData["Title"] = "Search Results";

    var searchType        = ViewBag.SearchType as string;
    var fromCode          = ViewBag.FromCode as string;
    var fromName          = ViewBag.FromName as string;
    var fromCoordinates   = ViewBag.FromCoordinates as string;
    var isFromSearch      = searchType == "from";
    var originHasStopCode = !string.IsNullOrEmpty(fromCode);
}

@* ── Context bar (destination search only) ─────────────────────────── *@
@if (!isFromSearch)
{
    <div class="text-muted mb-2" style="font-size:.7rem">
        From: <span class="text-dark fw-medium">@fromName</span>
    </div>
}

@* ── Result list ────────────────────────────────────────────────────── *@
@if (Model?.Features?.Any() == true)
{
    @foreach (var feature in Model.Features.Where(f => !string.IsNullOrEmpty(f.Properties?.Id)))
    {
        var isValid       = feature.IsValidForJourney;
        var hasValidId    = feature.HasStopPlaceId;
        var coordinates   = feature.Geometry?.Coordinates != null && feature.Geometry.Coordinates.Length >= 2
            ? $"{feature.Geometry.Coordinates[0]},{feature.Geometry.Coordinates[1]}"
            : null;
        var opacityClass  = isValid ? "" : "opacity-50";

        <div class="border-bottom py-2 @opacityClass">

            @* Name + optional disambiguating label *@
            <div class="fw-medium text-truncate" style="font-size:.85rem">@feature.Properties?.Name</div>
            @if (!string.IsNullOrWhiteSpace(feature.Properties?.Label) && feature.Properties.Label != feature.Properties?.Name)
            {
                <div class="text-muted text-truncate" style="font-size:.7rem">@feature.Properties?.Label</div>
            }

            @if (!isValid)
            {
                <div class="text-danger fw-semibold" style="font-size:.7rem">
                    <i class="bi bi-exclamation-triangle"></i> Not available for journey planning
                </div>
            }

            @* Select button — route to GetTrip only when BOTH origin and destination have stop codes *@
            @if (isValid)
            {
                @if (isFromSearch)
                {
                    <a href="@(hasValidId
                        ? Url.Action("To", new { fromCode = feature.Properties?.Id, fromName = feature.Properties?.Name })
                        : Url.Action("To", new { fromName = feature.Properties?.Name, fromCoordinates = coordinates }))"
                       class="btn btn-primary btn-sm w-100 mt-1" style="font-size:.75rem">Select as From</a>
                }
                else
                {
                    @if (originHasStopCode && hasValidId)
                    {
                        <a href="@Url.Action("GetTrip", new { fromCode, toCode = feature.Properties?.Id })"
                           class="btn btn-success btn-sm w-100 mt-1" style="font-size:.75rem">Select as Destination</a>
                    }
                    else
                    {
                        <a href="@Url.Action("GetTripWithCoordinates", new {
                            fromCode = originHasStopCode ? fromCode : null,
                            fromName = originHasStopCode ? null : fromName,
                            fromCoordinates = originHasStopCode ? null : fromCoordinates,
                            toCode = hasValidId ? feature.Properties?.Id : null,
                            toName = hasValidId ? null : feature.Properties?.Name,
                            toCoordinates = hasValidId ? null : coordinates
                        })"
                           class="btn btn-success btn-sm w-100 mt-1" style="font-size:.75rem">Select as Destination</a>
                    }
                }
            }
            else
            {
                <button disabled class="btn btn-outline-secondary btn-sm w-100 mt-1" style="font-size:.75rem; cursor: not-allowed;">Not selectable</button>
            }

        </div>
    }
}
else
{
    <p class="text-muted" style="font-size:.8rem">No results found. Try a different search term.</p>
}

@* ── Back navigation ────────────────────────────────────────────────── *@
<div class="mt-3">
    @if (isFromSearch)
    {
        <a href="@Url.Action("From")"
           class="text-decoration-none text-muted" style="font-size:.75rem">← Back</a>
    }
    else
    {
        <a href="@Url.Action("To", new { fromCode, fromName, fromCoordinates })"
           class="text-decoration-none text-muted" style="font-size:.75rem">← Back</a>
    }
}
